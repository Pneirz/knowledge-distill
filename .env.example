# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# LLM model (default: claude-sonnet-4-6)
LLM_MODEL=claude-sonnet-4-6

# Embedding model for semantic search (default: BAAI/bge-small-en-v1.5)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Data root directory (default: data/ relative to project root)
KNOWLEDGE_DATA_ROOT=data

# Chunking parameters
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP=64
