# LLM backend: claude-code | codex | anthropic
LLM_BACKEND=claude-code

# Optional: only required when LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# LLM model
# Examples:
# - claude-code: claude-sonnet-4-6
# - codex: gpt-5
# - anthropic: claude-sonnet-4-6
LLM_MODEL=claude-sonnet-4-6

# Embedding model for semantic search (default: BAAI/bge-small-en-v1.5)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Data root directory (default: data/ relative to project root)
KNOWLEDGE_DATA_ROOT=data

# Chunking parameters
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP=64
